{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "functions": {
    "api/share.js": {
      "maxDuration": 30,
      "memory": 256
    }
  },
  "rewrites": [
    { "source": "/api/share", "destination": "/api/share" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
